// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Establishment {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  address   String
  website   String?
  bills     Bill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("establishments")
}

model Bill {
  id              String        @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  invoice         Invoice?
  payment         Payment?
  taxes           Taxes?
  items           Item[]
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("bills")
}

model Invoice {
  id                    String   @id @default(cuid())
  billId                String   @unique
  bill                  Bill     @relation(fields: [billId], references: [id])
  number                String
  series                String
  issuedAt              DateTime
  capturedAt            DateTime
  accessKey             String   @unique
  authorizationProtocol String
  environment           String
  xmlVersion            String
  xsltVersion           String
  type                  String
  via                   String
  consumer              String
  operator              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("invoices")
}

model Payment {
  id          String   @id @default(cuid())
  billId      String   @unique
  bill        Bill     @relation(fields: [billId], references: [id])
  totalItems  Int
  totalAmount Decimal  @db.Decimal(10, 2)
  amountPaid  Decimal  @db.Decimal(10, 2)
  change      Decimal  @db.Decimal(10, 2)
  method      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payments")
}

model Taxes {
  id            String   @id @default(cuid())
  billId        String   @unique
  bill          Bill     @relation(fields: [billId], references: [id])
  totalTaxes    Decimal  @db.Decimal(10, 2)
  taxPercentage Decimal  @db.Decimal(5, 2)
  taxSource     String
  legalBasis    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("taxes")
}

model Item {
  id          String   @id @default(cuid())
  billId      String
  bill        Bill     @relation(fields: [billId], references: [id])
  code        String
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unit        String
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("items")
}

model Product {
  id        String           @id @default(cuid())
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  mappings  ProductMapping[]
  items     Item[]

  @@map("products")
}

model ProductMapping {
  id                    String   @id @default(cuid())
  normalizedDescription String   @unique
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  createdAt             DateTime @default(now())

  @@index([normalizedDescription])
  @@map("product_mappings")
}

model RandomValue {
  id          String    @id @default(cuid())
  value       String
  nome        String?
  cpf         String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("random_values")
}

model RequestLog {
  id         String   @id @default(cuid())
  sessionId  String
  ipAddress  String?
  userAgent  String?
  path       String
  method     String
  city       String?
  region     String?
  country    String?
  geoFetched Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@map("request_logs")
}

// ── Backoffice ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ENTITY_ADMIN
  READER
}

model Entity {
  id                String        @id @default(cuid())
  cnpj              String        @unique
  name              String
  address           String
  phone             String?
  logo              String?
  notificationPhone String?
  weekDays          Int           @default(7)
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  users             User[]
  readings          UserReading[]
  goals             ReadingGoal[]

  @@map("entities")
}

model User {
  id        String        @id @default(cuid())
  name      String
  cpf       String        @unique
  phone     String?
  email     String        @unique
  password  String
  role      Role          @default(READER)
  entityId  String?
  entity    Entity?       @relation(fields: [entityId], references: [id])
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  readings  UserReading[]
  goals     ReadingGoal[]

  @@index([email])
  @@index([entityId])
  @@map("users")
}

model UserReading {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  readerName String?
  readerCpf  String?
  accessKey    String
  entityId     String?
  entity       Entity?   @relation(fields: [entityId], references: [id])
  nfpDonatedAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
  @@map("user_readings")
  // partial unique index on (userId, accessKey) WHERE userId IS NOT NULL applied directly in DB
}

model ReadingGoal {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  entityId   String
  entity     Entity    @relation(fields: [entityId], references: [id])
  weekStart  DateTime
  target     Int
  recurring  Boolean   @default(false)
  createdBy  String
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, weekStart])
  @@index([entityId])
  @@index([weekStart])
  @@map("reading_goals")
}
